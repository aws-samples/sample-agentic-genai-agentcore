# S3 Configuration
# The S3 bucket name where campaign files and reviews are stored
VITE_S3_BUCKET=unified-campaign-review-test

# API Configuration
# The base URL for the backend API (upload, reviews, health endpoints)
VITE_API_URL=http://localhost:3001

# AWS Configuration for Bedrock Agent Runtime
# The AWS region where your agent is deployed
VITE_AWS_REGION=us-west-2

# The Agent Runtime ARN from your deployment
# You can find this in the deployment output or AWS Console
# Format: arn:aws:bedrock-agentcore:region:account-id:agent-runtime/agent-id
VITE_AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:agent-runtime/your-agent-id

# Note: For browser-based AWS SDK usage, you need AWS credentials
# Options:
# 1. Use AWS Cognito Identity Pool (recommended for production)
# 2. Use temporary credentials from your backend
# 3. For development only, you can set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
#    but NEVER commit these to version control
