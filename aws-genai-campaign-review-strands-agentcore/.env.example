# NVIDIA NIMs API Configuration
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_KEY=nvapi-your-key-here

# S3 Configuration
# The S3 bucket name where campaign files and reviews are stored
VITE_S3_BUCKET=unified-campaign-review-test

# API Configuration
# The base URL for the backend API (upload, reviews, health endpoints)
VITE_API_URL=http://localhost:3001

# The full URL for the Agent API (review-campaign endpoint on REST API Gateway)
# This is the ServerlessRestApi endpoint, NOT the HttpApi
# The review-campaign Lambda invokes AgentCore via SDK using the ARN from SSM
VITE_AGENT_API_URL=https://xxxxxxxx.execute-api.us-west-2.amazonaws.com/Prod/review-campaign
