{
  "examples": {
    "deploy": {
      "description": "Deploy a new agent to Agent Core Runtime",
      "payload": {
        "action": "deploy",
        "agent_name": "campaign_review_agent",
        "region": "us-west-2",
        "test_payload": {
          "campaignId": "test-campaign-001",
          "s3Key": "campaigns/test-campaign-001/campaign_brief.md"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "success": true,
          "action": "deploy",
          "agent_id": "abc123xyz",
          "agent_arn": "arn:aws:bedrock-agentcore:us-west-2:123456789012:agent-runtime/abc123xyz",
          "ecr_uri": "123456789012.dkr.ecr.us-west-2.amazonaws.com/campaign_review_agent",
          "status": "READY",
          "test_invocation": {
            "success": true,
            "response": "Test invocation completed"
          }
        }
      }
    },
    
    "status": {
      "description": "Get the status of an existing agent",
      "payload": {
        "action": "status",
        "agent_id": "abc123xyz",
        "region": "us-west-2"
      },
      "response": {
        "statusCode": 200,
        "body": {
          "success": true,
          "action": "status",
          "agent_id": "abc123xyz",
          "status": {
            "agentRuntimeId": "abc123xyz",
            "status": "READY",
            "createdAt": "2024-01-01T00:00:00Z"
          }
        }
      }
    },
    
    "invoke": {
      "description": "Invoke an existing agent",
      "payload": {
        "action": "invoke",
        "agent_arn": "arn:aws:bedrock-agentcore:us-west-2:123456789012:agent-runtime/abc123xyz",
        "region": "us-west-2",
        "payload": {
          "campaignId": "campaign-123",
          "s3Key": "campaigns/campaign-123/campaign_brief.md"
        }
      },
      "response": {
        "statusCode": 200,
        "body": {
          "success": true,
          "action": "invoke",
          "agent_arn": "arn:aws:bedrock-agentcore:us-west-2:123456789012:agent-runtime/abc123xyz",
          "response": "Agent response data..."
        }
      }
    },
    
    "delete": {
      "description": "Delete an agent and its ECR repository",
      "payload": {
        "action": "delete",
        "agent_id": "abc123xyz",
        "ecr_repo_name": "campaign_review_agent",
        "region": "us-west-2"
      },
      "response": {
        "statusCode": 200,
        "body": {
          "success": true,
          "action": "delete",
          "agent_id": "abc123xyz",
          "deleted": {
            "agent_deleted": true,
            "ecr_deleted": true
          }
        }
      }
    }
  },
  
  "curl_examples": {
    "deploy": "curl -X POST https://your-api-gateway-url/deploy -H 'Content-Type: application/json' -d '{\"action\":\"deploy\",\"agent_name\":\"campaign_review_agent\",\"region\":\"us-west-2\"}'",
    
    "status": "curl -X POST https://your-api-gateway-url/deploy -H 'Content-Type: application/json' -d '{\"action\":\"status\",\"agent_id\":\"abc123xyz\",\"region\":\"us-west-2\"}'",
    
    "invoke": "curl -X POST https://your-api-gateway-url/deploy -H 'Content-Type: application/json' -d '{\"action\":\"invoke\",\"agent_arn\":\"arn:aws:bedrock-agentcore:us-west-2:123456789012:agent-runtime/abc123xyz\",\"payload\":{\"campaignId\":\"campaign-123\",\"s3Key\":\"campaigns/campaign-123/campaign_brief.md\"}}'",
    
    "delete": "curl -X POST https://your-api-gateway-url/deploy -H 'Content-Type: application/json' -d '{\"action\":\"delete\",\"agent_id\":\"abc123xyz\",\"ecr_repo_name\":\"campaign_review_agent\",\"region\":\"us-west-2\"}'"
  },
  
  "aws_cli_examples": {
    "deploy": "aws lambda invoke --function-name DeployAgentCoreFunction --payload '{\"action\":\"deploy\",\"agent_name\":\"campaign_review_agent\"}' response.json",
    
    "status": "aws lambda invoke --function-name DeployAgentCoreFunction --payload '{\"action\":\"status\",\"agent_id\":\"abc123xyz\"}' response.json",
    
    "invoke": "aws lambda invoke --function-name DeployAgentCoreFunction --payload '{\"action\":\"invoke\",\"agent_arn\":\"arn:aws:bedrock-agentcore:us-west-2:123456789012:agent-runtime/abc123xyz\",\"payload\":{\"campaignId\":\"campaign-123\",\"s3Key\":\"campaigns/campaign-123/campaign_brief.md\"}}' response.json",
    
    "delete": "aws lambda invoke --function-name DeployAgentCoreFunction --payload '{\"action\":\"delete\",\"agent_id\":\"abc123xyz\",\"ecr_repo_name\":\"campaign_review_agent\"}' response.json"
  }
}
